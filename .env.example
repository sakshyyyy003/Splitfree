# Supabase
# Project URL — used by all clients (browser, server, service, middleware)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
# Anon key — public, safe for the browser; used by browser client (client.ts),
# server client (server.ts), and middleware (middleware.ts)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — secret, NEVER expose to the browser; used only by
# service client (service.ts) to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Cron
CRON_SECRET=your-cron-secret
