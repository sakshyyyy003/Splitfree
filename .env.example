# Supabase
# Project URL from Supabase dashboard > Settings > API (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
# Anon/public key from Supabase dashboard > Settings > API (exposed to browser, safe for client-side use with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key from Supabase dashboard > Settings > API
# WARNING: This key bypasses Row Level Security. Never prefix with NEXT_PUBLIC_. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Cron
CRON_SECRET=your-cron-secret
