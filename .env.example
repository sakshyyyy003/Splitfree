# Supabase
# Project URL — used by all clients (browser, server, service, middleware)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
# Publishable key — public, safe for the browser; used by browser client (client.ts),
# server client (server.ts), and middleware (middleware.ts)
# Replaces the legacy anon key (sb_publishable_... format)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Secret key — NEVER expose to the browser; used only by
# service client (service.ts) to bypass RLS for admin operations
# Replaces the legacy service_role key (sb_secret_... format)
SUPABASE_SECRET_KEY=your-secret-key

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Cron
CRON_SECRET=your-cron-secret
